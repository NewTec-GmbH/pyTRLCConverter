@startuml

class BaseConverter {
}

class RstConverter extends BaseConverter {
    +get_subcommand() : str
    +get_description() : str
    +register(args_parser: Any) : None
    +begin() : Ret
    +enter_file(file_name: str) : Ret
    +leave_file(file_name: str) : Ret
    +convert_section(section: str, level: int) : Ret
    +convert_record_object_generic(record: Record_Object, level: int, translation: Optional[dict]) : Ret
    +finish() : Ret
}

note right of RstConverter
    Builds a reStructuredText AST (RstDocument)
    while walking the TRLC symbols and writes
    the output file(s) only once the document
    is complete:
    * leave_file()  -> multiple-document mode
    * finish()      -> single-document mode
end note

package "reStructuredText AST" {

    abstract class RstElement {
        +{abstract} render() : str
    }

    class RstHeading extends RstElement {
        +render() : str
    }
    class RstAdmonition extends RstElement {
        +render() : str
    }
    class RstTable extends RstElement {
        +render() : str
    }
    class RstBulletList extends RstElement {
        +render() : str
    }
    class RstImage extends RstElement {
        +render() : str
    }
    class RstRawText extends RstElement {
        +render() : str
    }

    class RstDocument {
        +add(element: RstElement) : None
        +is_empty() : bool
        +render() : str
    }

    class RstText <<utility>> {
        +{static} escape(text: str) : str
        +{static} link(text: str, target: str, escape: bool) : str
        +{static} role(text: str, role: str, escape: bool) : str
    }

    note bottom of RstDocument
        render() concatenates the block
        elements, separating consecutive
        blocks by a single blank line.
    end note

    RstDocument o-- "0..*" RstElement
    RstHeading ..> RstText
    RstAdmonition ..> RstText
    RstTable ..> RstText
    RstImage ..> RstText
    RstBulletList ..> RstText
}

RstConverter *-- RstDocument
RstConverter ..> RstElement : builds
RstConverter ..> RstText

' Define external dependencies
package "Dependencies" {

    class trlc <<(M ,lightblue) module>>{
    }

    note bottom of trlc
        Use TRLC ast items:
        * Implicit_Null
        * Record_Object
        * Record_Reference
        * String_Literal
        * Expression
    end note

    class TrlcAstWalker {
        + walk(ast: Any) : None
    }

    class Md2RstRenderer {
        + render(ast: Any) : str
    }

    class Gfm2RstRenderer extends Md2RstRenderer {
    }

    class marko <<(M ,lightblue) module>> {
    }
    note bottom of marko
        Markdown Parser
    end note

    class PlantUML {
    }
    note bottom of PlantUML
        Renders inline ```plantuml```
        fenced code blocks to SVG.
    end note
}

' Relationships
RstConverter ..> trlc
RstConverter ..> TrlcAstWalker
RstConverter ..> Md2RstRenderer
RstConverter ..> Gfm2RstRenderer
RstConverter ..> marko
Md2RstRenderer ..> PlantUML

@enduml