package Requirements

enum Status {
    Draft
    Approved
    Rejected
}

type Heading {
    description String
}

type Image {
    file_path   String
    caption     String
    status      Status
}

type Information {
    description String
    status      Status
}

type Requirement {
    name                    String
    description             String
    derived     optional    Requirement[0 .. *]
    status                  Status
}
