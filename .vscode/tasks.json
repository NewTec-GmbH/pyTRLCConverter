{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate GFM docx test output",
            "type": "shell",
            "command": ".venv/Scripts/pyTRLCConverter",
            "args": [
                "--source", "tests/utils/req.rsl",
                "--source", "tests/utils/single_req_description_gfm.trlc",
                "--out", "tests/out",
                "--renderCfg", "tests/utils/renderCfgDocxGfm.json",
                "docx",
                "--template", "tests/utils/template.docx"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
